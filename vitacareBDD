

CREATE DATABASE IF NOT EXISTS vitacare CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE vitacare;

-- USERS

CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nom VARCHAR(100) NOT NULL,
    prenom VARCHAR(100) NOT NULL,
    email VARCHAR(150) NOT NULL UNIQUE,
    mot_de_passe VARCHAR(255) NOT NULL,          -- bcrypt hash
    role ENUM('client', 'intervenant', 'admin') NOT NULL DEFAULT 'client',
    telephone VARCHAR(20),
    photo VARCHAR(255),
    date_naissance DATE,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


-- SERVICES

CREATE TABLE services (
    id INT AUTO_INCREMENT PRIMARY KEY,
    titre VARCHAR(150) NOT NULL,
    description TEXT,
    categorie ENUM('consultation', 'therapie', 'bien_etre', 'nutrition', 'sport', 'meditation', 'autre') NOT NULL DEFAULT 'autre',
    duree_minutes INT NOT NULL DEFAULT 60,
    prix DECIMAL(8,2) NOT NULL DEFAULT 0.00,
    intervenant_id INT,                          -- FK vers users (role intervenant)
    image VARCHAR(255),
    actif TINYINT(1) NOT NULL DEFAULT 1,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (intervenant_id) REFERENCES users(id) ON DELETE SET NULL
);


-- DISPONIBILITÉS des intervenants

CREATE TABLE disponibilites (
    id INT AUTO_INCREMENT PRIMARY KEY,
    intervenant_id INT NOT NULL,
    service_id INT NOT NULL,
    date_heure_debut DATETIME NOT NULL,
    date_heure_fin DATETIME NOT NULL,
    places_max INT NOT NULL DEFAULT 1,
    statut ENUM('disponible', 'complet', 'annule') NOT NULL DEFAULT 'disponible',
    FOREIGN KEY (intervenant_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (service_id) REFERENCES services(id) ON DELETE CASCADE
);


-- RESERVATIONS (rendez-vous individuels)

CREATE TABLE reservations (
    id INT AUTO_INCREMENT PRIMARY KEY,
    client_id INT NOT NULL,
    disponibilite_id INT NOT NULL,
    statut ENUM('en_attente', 'confirmee', 'annulee', 'refusee') NOT NULL DEFAULT 'en_attente',
    notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (client_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (disponibilite_id) REFERENCES disponibilites(id) ON DELETE CASCADE,
    UNIQUE KEY no_double_reservation (client_id, disponibilite_id)   -- pas de double réservation
);


-- ACTIVITÉS (ateliers collectifs)

CREATE TABLE activites (
    id INT AUTO_INCREMENT PRIMARY KEY,
    titre VARCHAR(150) NOT NULL,
    description TEXT,
    categorie ENUM('nutrition', 'relaxation', 'sport', 'prevention', 'meditation', 'atelier', 'autre') NOT NULL DEFAULT 'autre',
    intervenant_id INT,
    date_heure_debut DATETIME NOT NULL,
    date_heure_fin DATETIME NOT NULL,
    lieu VARCHAR(200),
    places_max INT NOT NULL DEFAULT 10,
    prix DECIMAL(8,2) NOT NULL DEFAULT 0.00,
    image VARCHAR(255),
    statut ENUM('ouverte', 'complete', 'annulee', 'terminee') NOT NULL DEFAULT 'ouverte',
    date_limite_inscription DATETIME,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (intervenant_id) REFERENCES users(id) ON DELETE SET NULL
);


-- INSCRIPTIONS aux activités

CREATE TABLE inscriptions (
    id INT AUTO_INCREMENT PRIMARY KEY,
    client_id INT NOT NULL,
    activite_id INT NOT NULL,
    statut ENUM('en_attente', 'confirmee', 'annulee', 'refusee') NOT NULL DEFAULT 'en_attente',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (client_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (activite_id) REFERENCES activites(id) ON DELETE CASCADE,
    UNIQUE KEY no_double_inscription (client_id, activite_id)
);


-- NOTIFICATIONS

CREATE TABLE notifications (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    titre VARCHAR(200) NOT NULL,
    message TEXT NOT NULL,
    type ENUM('reservation', 'annulation', 'modification', 'inscription', 'systeme') NOT NULL DEFAULT 'systeme',
    lu TINYINT(1) NOT NULL DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);


